{
  "name": "amakodomoshokudou.org.v2",
  "type": "module",
  "version": "1.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "dev:mock": "astro dev --mode mock",
    "build:mock": "astro build --mode mock",
    "start": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint:html": "markuplint --allow-warnings 'dist/**/*.html'",
    "format": "prettier --write .",
    "lint:biome": "biome check",
    "lint": "pnpm run lint:biome && pnpm run lint:html",
    "vrt": "pnpm exec playwright test",
    "vrt:upgrade": "pnpm vrt --update-snapshots"
  },
  "dependencies": {
    "@astrojs/compiler-rs": "^0.1.7",
    "@astrojs/sitemap": "3.7.1",
    "astro": "6.1.7",
    "microcms-js-sdk": "^3.4.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "2.4.10",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "markuplint": "^4.14.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
