{
  "name": "amakodomoshokudou.org.v2",
  "type": "module",
  "version": "1.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "dev:mock": "astro dev --mode mock",
    "build:mock": "astro build --mode mock",
    "start": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint:html": "markuplint --allow-warnings 'dist/**/*.html'",
    "format": "prettier --write .",
    "lint:biome": "biome check",
    "lint": "pnpm run lint:biome && pnpm run lint:html",
    "vrt": "pnpm exec playwright test",
    "vrt:update": "pnpm vrt --update-snapshots"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.0.2",
    "microcms-js-sdk": "^3.4.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "markuplint": "^4.18.3",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
